<?xml version="1.0" encoding="utf-8"?>
<robot  xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <!-- MESHES -->
    <xacro:property name="mesh_path" value="file://$(find robot_description)/meshes" />

    <xacro:property name="gripper_base"         value="${mesh_path}/gripper_base.STL" />
    <xacro:property name="gripper_left_jaw"     value="${mesh_path}/gripper_left_jaw_link.STL" />
    <xacro:property name="gripper_right_jaw"    value="${mesh_path}/gripper_right_jaw_link.STL" />

    <!-- LINKS -->
    <!-- Link gripper base -->
    <link name="gripper_base">
        <inertial>
            <origin
                xyz="-0.000183807162235591 8.05033155577911E-05 0.0321436689908876" rpy="0 0 0" />
            <mass value="0.45" />
            <inertia ixx="0.00092934" ixy="0.00000034" ixz="-0.00000738"
                     iyy="0.00071447" iyz="0.00000005" izz="0.00039442" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_base}" />
            </geometry>
            <material name="">
                <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_base}" />
            </geometry>
        </collision>
    </link> 

    <!-- Link gripper left jaw -->
    <link name="gripper_left_jaw">
        <inertial>
            <origin
                xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025" rpy="0 0 0" />
            <mass value="0.025" />
            <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021"
                     iyy="0.00000781" iyz="-0.00001372" izz="0.0000747" />
        </inertial>
        <visual> 
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_left_jaw}" />
            </geometry>
            <material name="">
                <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_left_jaw}" />
            </geometry>
        </collision>
    </link>

    <!-- Link gripper right jaw -->
    <link name="gripper_right_jaw">
        <inertial>
            <origin xyz="0.000651231850419722 -0.0491929869131991 0.00972258769184024" rpy="0 0 0" />
            <mass value="0.025" />
            <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021"
                     iyy="0.00000781" iyz="-0.00001372" izz="0.0000747" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_right_jaw}" />
            </geometry>
            <material name="">
                <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${gripper_right_jaw}" />
            </geometry>
        </collision>
    </link>


    <!-- JOINTS -->
    <!-- gripper base → link6  (end-effector flange) -->
    <joint name="joint6_to_gripper_base" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="link6" />
        <child link="gripper_base" />
    </joint>

    <!-- gripper left jaw → gripper base -->
    <joint name="right_jaw_to_gripper_base" type="prismatic">
        <origin xyz="0 0 0.1358" rpy="1.5708 0 0" />
        <parent link="gripper_base" />
        <child link="gripper_left_jaw" />
        <axis xyz="0 0 1" />
        <limit lower="0" upper="0.035" effort="10" velocity="1" />
    </joint>

    <!-- gripper right jaw → gripper base -->
    <joint name="left_jaw_to_gripper_base" type="prismatic">
        <origin xyz="0 0 0.1358" rpy="1.5708 0 -3.1416" />
        <parent link="gripper_base" />
        <child link="gripper_right_jaw" />
        <axis xyz="0 0 -1" />
        <limit lower="-0.035" upper="0" effort="10" velocity="1" />
    </joint>

</robot>
